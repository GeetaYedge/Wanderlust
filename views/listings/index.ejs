<% layout('layouts/boilerplate') %>

  <style>
    /* Wrapper for filters + toggle */
    #filters-wrapper {
      display: flex;
      align-items: center;
      position: relative;
      padding-right: 1rem;
    }

    /* Filters container */
    #filters {
      display: flex;
      flex-wrap: nowrap;
      overflow-x: auto;
      padding-left: 1rem;
      margin-top: 1.5rem;
      padding-bottom: 0.5rem;
      flex: 1;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
    }

    /* Individual filters */
    .filter {
      flex: 0 0 auto;
      margin-right: 1.8rem;
      scroll-snap-align: start;
      text-align: center;
      opacity: 0.7;
      font-size: 1.2rem;
      text-decoration: none;
      color: inherit;
    }

    .filter:hover {
      opacity: 1;
      cursor: pointer;
    }

    .filter p {
      font-size: 0.8rem;
    }

    /* Active filter highlight */
    .active-filter {
      opacity: 1 !important;
      font-weight: bold;
      text-decoration: underline;
    }

    /* Toggle button inside same wrapper */
    .tax-toggle {
      flex: 0 0 auto;
      position: sticky;
      right: 0;
      top: 0;
      z-index: 100;
      padding: 1rem;
      height: 3.25rem;
      border-radius: 1rem;
      border: 1px solid black;
      background-color: #fff;
      display: flex;
      align-items: center;
      transition: all 0.3s ease;
    }

    /* Optional: custom horizontal scrollbar */
    #filters::-webkit-scrollbar {
      height: 6px;
    }

    #filters::-webkit-scrollbar-thumb {
      background-color: rgba(0, 0, 0, 0.2);
      border-radius: 3px;
    }

    /* Responsive: smaller toggle on mobile */
    @media (max-width: 768px) {
      .tax-toggle {
        padding: 0.5rem 0.75rem;
        height: 2.5rem;
        font-size: 0.8rem;
        margin-left: 0.5rem;
      }
    }
  </style>

  <!-- Filters + Toggle Wrapper -->
  <div id="filters-wrapper">
    <div id="filters">
      <% filters.forEach(f=> { %>
        <a href="/listings?filter=<%= f.name %>" class="filter <%= selectedFilter === f.name ? 'active-filter' : '' %>">
          <div><i class="fa-solid <%= f.icon %>"></i></div>
          <p>
            <%= f.name %>
          </p>
        </a>
        <% }) %>
    </div>

    <!-- Toggle button -->
    <div class="tax-toggle">
      <div class="form-check-reverse form-switch">
        <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
        <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
      </div>
    </div>
  </div>

  <!-- Listings -->
  <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
    <% for (let listing of allListings) { %>
      <div class="col mb-4">
        <a href="/listings/<%= listing._id %>" class="listing-link">
          <div class="card col listing-card">
            <img src="<%= listing.image.url %>" class="card-img-top" alt="listing image"
              style="height: 20rem; object-fit: cover;" />
            <div class="card-img-overlay"></div>
            <div class="card-body">
              <p class="card-text">
                <b>
                  <%= listing.title %>
                </b><br>
                &#8377; <%= listing.price.toLocaleString("en-IN") %> / night
                  <i class="tax-info">&nbsp; &nbsp;+18% GST</i>
              </p>
            </div>
          </div>
        </a>
      </div>
      <% } %>
  </div>

  <script>
    // Toggle GST
    let taxSwitch = document.getElementById("switchCheckDefault");
    taxSwitch.addEventListener("click", () => {
      let taxInfo = document.getElementsByClassName("tax-info");
      for (info of taxInfo) {
        info.style.display = (info.style.display !== "inline") ? "inline" : "none";
      }
    });
  </script>